#!/usr/bin/env bash
set -euo pipefail

SW_FILE="service-worker.js"

if [ ! -f "$SW_FILE" ]; then
  exit 0
fi

# Ensure git will notice changes to the service worker.
git update-index --no-assume-unchanged "$SW_FILE" 2>/dev/null || true

# Expected format: const CACHE_NAME = 'wordcards-vN';
current=$(rg -n "^const CACHE_NAME = 'wordcards-v([0-9]+)';" -r '$1' "$SW_FILE" | head -n 1 || true)
if [ -z "$current" ]; then
  exit 0
fi

next=$((current + 1))

sed -i '' "s/^const CACHE_NAME = 'wordcards-v[0-9]\+';/const CACHE_NAME = 'wordcards-v${next}';/" "$SW_FILE"

git add "$SW_FILE"
